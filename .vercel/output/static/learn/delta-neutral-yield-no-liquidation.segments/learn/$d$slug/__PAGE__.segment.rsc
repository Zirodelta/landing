25:["$","ul","ul-6",{"className":"space-y-2 mb-4 ml-4","children":["\n",["$","li","li-0",{"className":"text-muted-foreground leading-relaxed","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Liquidation of depositor collateral?"}]," No — architecturally prevented"]}],"\n",["$","li","li-1",{"className":"text-muted-foreground leading-relaxed","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"What happens instead?"}]," Protocol reduces farming positions (auto-deleverage)"]}],"\n",["$","li","li-2",{"className":"text-muted-foreground leading-relaxed","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"When?"}]," When $ZDLT collateral health degrades beyond safety threshold"]}],"\n",["$","li","li-3",{"className":"text-muted-foreground leading-relaxed","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Your tokens?"}]," Still yours. Still in the vault. Never sold."]}],"\n"]}]
26:["$","h2","h2-4",{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"The 5x Leverage Question"}]
27:["$","p","p-14",{"className":"text-muted-foreground leading-relaxed mb-4","children":"Zirodelta operates farming positions at 5x leverage on exchanges. Does this introduce liquidation risk?"}]
28:["$","p","p-15",{"className":"text-muted-foreground leading-relaxed mb-4","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"On the exchange level:"}]," Yes, individual farming positions on exchanges have margin requirements. Extreme price moves could theoretically liquidate a position leg."]}]
29:["$","p","p-16",{"className":"text-muted-foreground leading-relaxed mb-4","children":["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Mitigations built into the engine:"}]}]
2a:["$","ul","ul-7",{"className":"space-y-2 mb-4 ml-4","children":["\n",["$","li","li-0",{"className":"text-muted-foreground leading-relaxed","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Delta-neutral pairs:"}]," Every position is a hedge pair (long on Exchange A, short on Exchange B). Net exposure is zero. A price move that hurts one leg helps the other."]}],"\n",["$","li","li-1",{"className":"text-muted-foreground leading-relaxed","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Conservative position sizing:"}]," The engine doesn't max out available margin."]}],"\n",["$","li","li-2",{"className":"text-muted-foreground leading-relaxed","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Continuous monitoring:"}]," FundingGuard monitors all open positions via WebSocket, triggering SmartExit before margin gets thin."]}],"\n",["$","li","li-3",{"className":"text-muted-foreground leading-relaxed","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Per-exchange caps:"}]," No single exchange holds more than a set percentage of total farming capital. Exchange failure is isolated."]}],"\n"]}]
2b:["$","p","p-17",{"className":"text-muted-foreground leading-relaxed mb-4","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"For depositors:"}]," Even if an individual farming position were to be liquidated on an exchange (the delta-neutral structure makes this unlikely), it's the protocol's borrowed USDT at risk — not your $ZDLT collateral in the vault. The vault architecture separates depositor collateral from trading capital."]}]
2c:["$","h2","h2-5",{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"The Bottom Line"}]
2d:["$","p","p-18",{"className":"text-muted-foreground leading-relaxed mb-4","children":"If you've been liquidated before — on Aave, on a perp exchange, in a DeFi vault — you know the feeling. It's not just the financial loss. It's that the system was designed to sell your assets to protect itself."}]
2e:["$","p","p-19",{"className":"text-muted-foreground leading-relaxed mb-4","children":"Zirodelta inverts this. When stress hits, the protocol protects your collateral by reducing its own operations. Positions shrink. Revenue may decrease temporarily. But your $ZDLT stays in the vault."}]
2f:["$","p","p-20",{"className":"text-muted-foreground leading-relaxed mb-4","children":"The tradeoff is lower capital efficiency and reduced revenue during drawdowns. Whether that tradeoff is worth the elimination of forced liquidation depends on how you value capital preservation versus capital efficiency."}]
30:["$","p","p-21",{"className":"text-muted-foreground leading-relaxed mb-4","children":"For many allocators, especially those managing other people's money, \"your tokens are never force-sold\" is worth more than an extra few percent of yield."}]
