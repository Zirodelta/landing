3e:["$","ul","ul-3",{"className":"space-y-2 mb-4 ml-4","children":["\n",["$","li","li-0",{"className":"text-muted-foreground leading-relaxed","children":"Staking: from inflation. Doesn't compensate for price drops."}],"\n",["$","li","li-1",{"className":"text-muted-foreground leading-relaxed","children":"DeFi farming: from trading fees and token incentives. Both collapse."}],"\n",["$","li","li-2",{"className":"text-muted-foreground leading-relaxed","children":"Lending: from borrowers. Borrowing demand evaporates."}],"\n",["$","li","li-3",{"className":"text-muted-foreground leading-relaxed","children":"Basis trading: from positive funding. Goes negative in bears."}],"\n",["$","li","li-4",{"className":"text-muted-foreground leading-relaxed","children":["Cross-exchange arbitrage: from rate dispersion between exchanges. ",["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Increases with volatility."}]]}],"\n"]}]
3f:["$","p","p-28",{"className":"text-muted-foreground leading-relaxed mb-4","children":"The strategies that survive downturns profit from structural features of markets, not from directional bets. Cross-exchange funding rate arbitrage is one of the few yield sources where bear market volatility is a tailwind, not a headwind."}]
