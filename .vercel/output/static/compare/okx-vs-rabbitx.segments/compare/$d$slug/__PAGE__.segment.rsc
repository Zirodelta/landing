6:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"OKX calculates funding rates every 8 hours using traditional mark-to-index price methodology, with rates typically ranging from -0.375% to +0.375% daily. RabbitX employs 1-hour funding intervals on Starknet, enabling more frequent position adjustments and potentially smoother rate convergence. The hourly mechanism allows for 24 funding payments per day versus OKX's 3, creating different arbitrage dynamics and risk profiles for traders."}]]}]
7:["$","$Lb",null,{"items":[{"question":"How do funding intervals affect arbitrage profitability between OKX and RabbitX?","answer":"RabbitX's hourly funding allows for 8x more frequent rate captures compared to OKX's 8-hour cycles. This creates opportunities for faster capital rotation but requires more active position management and monitoring."},{"question":"Which platform has better liquidity for funding rate arbitrage?","answer":"OKX maintains significantly higher liquidity across major pairs, making it more suitable for large position sizes. RabbitX offers growing liquidity but works better for smaller arbitrage strategies due to limited market depth."},{"question":"Are there gas costs to consider when arbitraging between these platforms?","answer":"OKX operates on traditional infrastructure with standard withdrawal fees. RabbitX eliminates gas costs for trading through Starknet's architecture, but bridge costs may apply when moving funds between Layer 1 and Layer 2."},{"question":"How do margin requirements compare for cross-platform strategies?","answer":"OKX's portfolio margin mode allows efficient capital utilization across multiple positions. RabbitX offers cross-margin but with limited pair selection, potentially requiring higher overall capital allocation for diversified strategies."}]}]
