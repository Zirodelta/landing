6:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Gate.io calculates funding rates every 8 hours using premium index methodology across major pairs, with rates typically ranging -0.375% to +0.375% daily. Paradex implements hourly funding calculations on StarkNet, allowing for more responsive rate adjustments but potentially higher volatility. Gate.io's longer intervals provide predictability for carry trades, while Paradex's frequent updates better track real-time sentiment shifts."}]]}]
7:["$","$Lc",null,{"items":[{"question":"Which exchange offers better funding rate arbitrage opportunities?","answer":"Gate.io provides more opportunities through 1,700+ pairs and established rate patterns, while Paradex offers hourly rate updates for faster arbitrage execution on limited pairs."},{"question":"How do funding intervals affect arbitrage strategies?","answer":"Gate.io's 8-hour intervals allow longer position holding and predictable settlement times, while Paradex's hourly funding enables rapid rate capture but requires more active monitoring."},{"question":"What are the custody differences between these platforms?","answer":"Gate.io requires depositing assets to exchange wallets with counterparty risk, while Paradex maintains user custody through StarkNet smart contracts with no exchange control."},{"question":"Which platform has lower overall trading costs?","answer":"Gate.io offers 0.015% maker fees versus Paradex's 0.02%, but Paradex eliminates withdrawal fees and potential exchange risks through self-custody architecture."}]}]
