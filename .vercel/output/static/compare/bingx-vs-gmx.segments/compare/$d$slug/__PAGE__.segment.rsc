b:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"BingX uses traditional 8-hour funding cycles typical of centralized exchanges, with rates determined by premium/discount to spot. GMX employs hourly funding payments calculated based on borrowing fees from GLP liquidity providers, creating more frequent but typically smaller rate adjustments. GMX's oracle-based system eliminates traditional funding rate volatility but introduces dependency on Chainlink price feeds. BingX offers more predictable funding schedules but potentially larger rate swings during high volatility periods."}]]}]
c:["$","$L10",null,{"items":[{"question":"Which exchange offers better funding rate opportunities?","answer":"BingX typically offers more predictable 8-hour cycles with potentially larger rate swings during volatility. GMX's hourly payments provide more frequent opportunities but smaller individual payments due to its GLP-based model."},{"question":"How do the fee structures impact funding arbitrage profitability?","answer":"BingX's lower trading fees (0.02%/0.05%) provide better net returns for frequent arbitrage strategies. GMX's higher fees (0.05%/0.07%) require larger funding rate differentials to maintain profitability but offer gas-efficient batch settlements."},{"question":"What are the main risks when arbitraging between these platforms?","answer":"Cross-chain bridge risks when moving funds to GMX on Arbitrum, oracle manipulation risks for GMX positions, and custody risks with BingX. GMX's hourly funding creates more frequent settlement exposure compared to BingX's 8-hour cycles."},{"question":"Which platform is better for automated funding rate strategies?","answer":"BingX offers native API access and copy trading features suitable for automated strategies. GMX requires smart contract interactions and Arbitrum gas management, making it more complex but potentially more profitable for sophisticated DeFi automation."}]}]
