6:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Both Aevo and Orderly use hourly funding intervals with similar rate calculation methodologies based on premium/discount to spot. Aevo's dedicated rollup enables faster rate updates and settlement, while Orderly's shared infrastructure aggregates funding across multiple frontend DEXs. Rate arbitrage opportunities may be more frequent on Aevo due to lower liquidity, whereas Orderly's pooled liquidity tends to stabilize rates faster."}]]}]
7:["$","$Lb",null,{"items":[{"question":"Which platform offers better funding rate arbitrage opportunities?","answer":"Aevo typically shows more rate volatility due to lower liquidity, creating frequent arbitrage windows. Orderly's shared liquidity pool tends to stabilize rates faster, reducing extreme opportunities but offering more consistent spreads."},{"question":"How do settlement mechanisms affect funding rate timing?","answer":"Aevo's rollup settlement processes funding immediately each hour with minimal delays. Orderly's cross-chain infrastructure may introduce slight settlement lag depending on the frontend DEX and underlying blockchain congestion."},{"question":"Can I trade the same perpetual contracts on both platforms?","answer":"Both support major crypto perpetuals like BTC and ETH, but Aevo focuses on options-related underlyings while Orderly's contract availability depends on which frontend DEX you're using within their network."},{"question":"Which platform has more predictable funding rates?","answer":"Orderly generally offers more stable funding rates due to aggregated liquidity from multiple sources. Aevo's rates can be more volatile, especially for newer or less liquid perpetual contracts."}]}]
