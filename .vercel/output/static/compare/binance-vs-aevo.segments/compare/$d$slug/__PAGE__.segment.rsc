6:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Binance calculates funding rates every 8 hours using a weighted average of premium and interest rate components across its massive liquidity pool. Aevo operates on 1-hour funding intervals with rates determined by its smaller but more concentrated liquidity on its dedicated rollup. The shorter intervals on Aevo allow for more responsive rate adjustments but create more frequent transaction costs. Binance's deeper liquidity typically results in more stable funding rates, while Aevo's rates can be more volatile due to concentrated positions."}]]}]
7:["$","$Lb",null,{"items":[{"question":"Which exchange offers better funding rate arbitrage opportunities?","answer":"Binance provides more stable rates with deeper liquidity for large positions, while Aevo's hourly funding creates more frequent arbitrage windows. Choice depends on position size and strategy timeframe."},{"question":"How do the funding rate calculation methods differ?","answer":"Binance uses 8-hour intervals with premium/interest rate weighting across 200+ pairs. Aevo calculates rates hourly on its rollup with smaller but concentrated liquidity pools."},{"question":"What are the key infrastructure differences for arbitrage?","answer":"Binance operates traditional centralized infrastructure with instant execution but regulatory constraints. Aevo uses rollup technology for on-chain settlement with potential MEV considerations."},{"question":"Which platform handles large arbitrage positions better?","answer":"Binance's deeper liquidity and $1B+ insurance fund make it superior for institutional-scale arbitrage. Aevo's smaller pools may cause significant slippage on large trades."}]}]
