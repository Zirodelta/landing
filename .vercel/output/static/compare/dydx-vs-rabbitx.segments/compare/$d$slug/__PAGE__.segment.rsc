6:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Both dYdX v4 and RabbitX use 1-hour funding intervals, making them suitable for active funding rate arbitrage strategies. dYdX calculates rates based on premium/discount to index price on its Cosmos appchain, while RabbitX uses Starknet for settlement with off-chain order matching. The identical funding frequencies mean rate differentials between the two can create direct arbitrage opportunities. RabbitX's zero gas trading may provide slight cost advantages, but dYdX's higher liquidity typically results in tighter spreads and more stable funding rates."}]]}]
7:["$","$Lc",null,{"items":[{"question":"Which exchange offers better funding rate arbitrage opportunities?","answer":"dYdX typically provides more stable funding rates due to higher liquidity, while RabbitX's lower user base can create more volatile rates with potentially higher profits but increased risk."},{"question":"How do gas costs affect profitability on each platform?","answer":"RabbitX eliminates gas costs for trading through its Starknet implementation, while dYdX v4 has minimal fees on its Cosmos appchain. Both are significantly cheaper than Ethereum mainnet alternatives."},{"question":"What are the main technical differences for traders?","answer":"dYdX operates on its own Cosmos blockchain with on-chain settlement, while RabbitX uses off-chain matching with Starknet settlement. Both offer similar API access and trading interfaces."},{"question":"Which platform is better for large funding rate positions?","answer":"dYdX generally handles larger positions better due to deeper liquidity and more established market maker presence. RabbitX may face slippage issues with significant position sizes."}]}]
