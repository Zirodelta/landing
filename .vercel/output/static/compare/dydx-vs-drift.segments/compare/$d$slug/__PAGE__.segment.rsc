9:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Both exchanges use 1-hour funding intervals making them suitable for active funding rate arbitrage. dYdX calculates rates using its native orderbook on the Cosmos appchain with USDC settlement. Drift employs a hybrid vAMM and DLOB model on Solana, using mark price from its virtual AMM while settling in USDC SPL tokens. Both follow similar funding rate formulas based on premium/discount to spot prices."}]]}]
a:["$","$Lf",null,{"items":[{"question":"Which exchange offers better funding rate opportunities?","answer":"Both use 1-hour intervals with similar rate calculation methods. Drift may offer more volatile rates due to its vAMM model, while dYdX provides more predictable rates from pure orderbook mechanics."},{"question":"How do transaction costs compare for funding arbitrage?","answer":"Drift has significantly lower gas costs on Solana (fractions of a cent) versus dYdX's Cosmos appchain fees. This makes Drift more suitable for frequent position adjustments in funding strategies."},{"question":"Which platform has better liquidity for large positions?","answer":"dYdX historically had deeper liquidity but volumes dropped post-migration. Drift's JIT auctions can provide competitive fills for larger orders despite lower baseline liquidity."},{"question":"Are there settlement or withdrawal differences?","answer":"dYdX settles natively in USDC on Cosmos requiring bridge operations for withdrawals. Drift uses Solana SPL USDC with direct access to Solana DeFi ecosystem for yield strategies."}]}]
