f:["$","section",null,{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":["Why ","MEME","/","USDT","?"]}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"MEME tokens exhibit high volatility and speculative interest, creating frequent funding rate imbalances on Orderly Network. The smaller trading volume compared to major altcoins can lead to more pronounced funding rate deviations. Shared liquidity across multiple DEX frontends provides unique arbitrage opportunities not available on traditional centralized exchanges."}]]}]
10:["$","section","0",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Historical Funding Rate Patterns"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"MEME/USDT on Orderly Network shows elevated funding rates during meme coin rallies, often exceeding 0.1% hourly during viral social media events. The shared liquidity model creates smoother rate transitions compared to isolated DEX pools. Weekend funding tends to normalize as institutional activity decreases across partner DEX frontends. Cross-chain arbitrageurs frequently exploit rate differentials between Orderly's NEAR-based settlement and Ethereum mainnet alternatives."}]]}]
11:["$","section","1",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Multi-Frontend Arbitrage Opportunities"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Orderly's infrastructure enables arbitrage across multiple DEX interfaces simultaneously accessing the same underlying liquidity. Traders can monitor funding rates while executing on preferred frontend partners like WOOFi or Ref Finance. The shared order book eliminates liquidity fragmentation typical in DEX trading. Cross-chain bridge delays create temporary funding rate premiums for patient arbitrageurs willing to wait for settlement windows."}]]}]
12:["$","section","2",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Risk Management Considerations"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"MEME token volatility can trigger rapid position liquidations despite favorable funding rates on Orderly Network. The complex architecture introduces smart contract risks across multiple chains and frontend interfaces. Smaller trading volumes may result in wider bid-ask spreads during volatile periods. Bridge congestion between NEAR and EVM chains can delay arbitrage execution and affect funding rate calculations."}]]}]
13:["$","$L15",null,{"items":[{"question":"How often are MEME/USDT funding rates updated on Orderly Network?","answer":"Funding rates settle every hour across all DEX frontends using Orderly's shared liquidity layer. The calculation uses mark price data aggregated from multiple partner exchanges to ensure accurate pricing."},{"question":"Can I arbitrage MEME funding rates across different Orderly DEX partners?","answer":"No, all DEX frontends share the same underlying order book and funding rates. Arbitrage opportunities exist between Orderly Network and external exchanges, not between partner DEX interfaces."},{"question":"What are the minimum position sizes for MEME/USDT funding arbitrage?","answer":"Minimum position sizes depend on the frontend DEX partner, typically ranging from $10-100 USDT equivalent. Consider the 0.05% taker fee when calculating minimum profitable arbitrage amounts."},{"question":"How does cross-chain settlement affect MEME funding rate arbitrage?","answer":"Cross-chain operations may introduce 5-10 minute delays for position transfers between NEAR and EVM chains. This latency can impact time-sensitive arbitrage strategies but creates opportunities for patient traders."}]}]
