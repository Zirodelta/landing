26:["$","ul","ul-3",{"className":"space-y-2 mb-4 ml-4","children":["\n",["$","li","li-0",{"className":"text-muted-foreground leading-relaxed","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Exchange risk"}]," — capital lives on exchanges. An exchange failure (FTX) means loss of funds on that venue."]}],"\n",["$","li","li-1",{"className":"text-muted-foreground leading-relaxed","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Execution risk"}]," — timing both legs of a hedge simultaneously. Brief directional exposure during entry/exit."]}],"\n",["$","li","li-2",{"className":"text-muted-foreground leading-relaxed","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Funding rate compression"}]," — spreads can narrow in low-volatility periods."]}],"\n",["$","li","li-3",{"className":"text-muted-foreground leading-relaxed","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Liquidation risk"}]," — leveraged positions can be liquidated in extreme moves (mitigated by conservative sizing)."]}],"\n",["$","li","li-4",{"className":"text-muted-foreground leading-relaxed","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Complexity"}]," — requires infrastructure, monitoring, multi-exchange APIs. Not a \"set and forget\" strategy."]}],"\n"]}]
27:["$","p","p-17",{"className":"text-muted-foreground leading-relaxed mb-4","children":[["$","strong","strong-0",{"className":"text-foreground font-semibold","children":"Key difference:"}]," Staking risk is ",["$","strong","strong-1",{"className":"text-foreground font-semibold","children":"directional"}]," — your P&L depends on token price. Arbitrage risk is ",["$","strong","strong-2",{"className":"text-foreground font-semibold","children":"operational"}]," — your P&L depends on execution quality and exchange solvency. Choose based on what you're more comfortable managing."]}]
