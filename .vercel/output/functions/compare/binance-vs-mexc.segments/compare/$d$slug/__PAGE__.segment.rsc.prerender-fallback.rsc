6:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Both exchanges use 8-hour funding intervals with similar premium/discount calculations based on perpetual-spot price differences. Binance's deeper liquidity typically results in more stable funding rates with smaller deviations, while MEXC's thinner books can create more volatile rates and arbitrage opportunities. Binance caps funding rates at ±0.75% per interval, whereas MEXC allows higher extremes up to ±2%, potentially offering better arbitrage returns but with increased risk."}]]}]
7:["$","$Ld",null,{"items":[{"question":"Which exchange offers better funding rate arbitrage opportunities?","answer":"MEXC offers higher potential returns due to zero maker fees and more volatile funding rates, but Binance provides more consistent opportunities with deeper liquidity and tighter spreads."},{"question":"How do the funding rate calculation methods differ between exchanges?","answer":"Both use similar premium/discount formulas, but Binance caps rates at ±0.75% while MEXC allows up to ±2%. Binance's calculations benefit from deeper liquidity data, resulting in more accurate rate predictions."},{"question":"What are the main execution risks when arbitraging between these platforms?","answer":"MEXC's thinner order books can cause significant slippage during volatile periods, while Binance may impose withdrawal delays. Cross-exchange arbitrage also faces counterparty risk differences between the platforms."},{"question":"Which platform is better for automated funding rate strategies?","answer":"Binance offers more reliable API performance and institutional-grade infrastructure, making it preferred for automated strategies. MEXC's APIs can be less stable but offer faster execution during low-traffic periods."}]}]
