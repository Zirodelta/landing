9:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Bybit calculates funding rates every 8 hours using premium index methodology, providing stability but less frequent arbitrage opportunities. Drift updates funding rates hourly through its vAMM system, enabling more responsive price discovery but requiring active monitoring. Bybit's traditional order book ensures predictable execution, while Drift's hybrid vAMM/DLOB model offers JIT liquidity but with potential slippage during high volatility."}]]}]
a:["$","$Le",null,{"items":[{"question":"How do funding intervals affect arbitrage profitability?","answer":"Drift's 1-hour intervals provide 8x more funding opportunities than Bybit's 8-hour cycles, enabling faster capital turnover but requiring more active position management and higher transaction frequency."},{"question":"Which exchange offers better liquidity for large positions?","answer":"Bybit typically provides deeper liquidity and tighter spreads for major pairs due to its established CEX infrastructure, while Drift's liquidity depends on JIT auctions and may have higher slippage for large orders."},{"question":"What are the key technical risks for each platform?","answer":"Bybit faces centralization and regulatory risks but offers stable uptime. Drift depends on Solana network stability and smart contract security, with potential for network congestion affecting execution."},{"question":"How do settlement mechanisms impact funding arbitrage?","answer":"Bybit uses USDT settlement with traditional banking-style processes, while Drift settles in USDC on Solana with near-instant finality, affecting capital efficiency and withdrawal timing for arbitrage strategies."}]}]
