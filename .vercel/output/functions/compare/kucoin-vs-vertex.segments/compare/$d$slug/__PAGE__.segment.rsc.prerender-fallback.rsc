6:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"KuCoin calculates funding rates every 8 hours using traditional mark-to-index price differences, creating longer arbitrage windows but less frequent adjustments. Vertex updates funding rates hourly through its hybrid architecture, where the off-chain sequencer calculates rates based on perpetual-spot basis but settles on Arbitrum. The 1-hour frequency on Vertex creates more responsive rate adjustments but requires active monitoring. KuCoin's longer intervals may accumulate larger rate deviations but offer more predictable timing for position management."}]]}]
7:["$","$Lb",null,{"items":[{"question":"Which exchange offers better funding rate arbitrage opportunities?","answer":"Vertex's hourly funding rate updates create more frequent arbitrage windows, while KuCoin's 8-hour intervals may accumulate larger rate deviations. Vertex also offers lower taker fees at 0.03% versus KuCoin's 0.06%."},{"question":"How do the funding rate calculation methods differ?","answer":"KuCoin uses traditional CEX methodology with 8-hour mark-to-index calculations. Vertex employs a hybrid approach with hourly updates through its off-chain sequencer, settling on Arbitrum for transparency."},{"question":"What are the liquidity differences for perpetual futures?","answer":"KuCoin typically offers deeper liquidity across major pairs and better altcoin perpetual selection. Vertex has growing liquidity but is concentrated on Arbitrum ecosystem with fewer trading pairs available."},{"question":"Which platform is better for automated funding rate strategies?","answer":"KuCoin provides established API infrastructure and trading bot marketplace integration. Vertex offers programmatic access through smart contracts but requires familiarity with Arbitrum development and may face sequencer dependency risks."}]}]
