6:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Both exchanges calculate funding rates using 8-hour intervals at 00:00, 08:00, and 16:00 UTC, applying the standard premium/discount formula based on perpetual-spot price divergence. Gate.io typically shows more stable rates due to deeper liquidity, while MEXC often exhibits higher rate volatility on newly listed tokens. Rate caps are similar at ±2.5%, though MEXC may experience more frequent extreme rate events during market stress."}]]}]
7:["$","$Lc",null,{"items":[{"question":"Which exchange offers better funding rate opportunities?","answer":"Gate.io provides more predictable rates with deeper liquidity, while MEXC offers higher rate volatility on new listings that can create larger arbitrage spreads but with increased risk."},{"question":"How do maker fees impact funding arbitrage profitability?","answer":"MEXC's zero maker fees provide a significant advantage, saving 0.015% per trade compared to Gate.io. This difference can substantially impact net returns on high-frequency arbitrage strategies."},{"question":"Which platform handles large arbitrage positions better?","answer":"Gate.io's deeper order books and higher liquidity make it more suitable for larger arbitrage positions, while MEXC works better for smaller trades due to potential slippage issues."},{"question":"Are funding rate calculation methods identical between platforms?","answer":"Both use standard 8-hour intervals with similar premium-based calculations, but Gate.io's rates tend to be more stable due to better market-making activity and liquidity depth."}]}]
