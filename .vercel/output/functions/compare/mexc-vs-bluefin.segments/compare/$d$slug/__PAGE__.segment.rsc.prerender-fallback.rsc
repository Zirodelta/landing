6:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"MEXC uses traditional 8-hour funding intervals with rates calculated from premium and interest components, often showing higher volatility due to aggressive altcoin listings. Bluefin implements hourly funding on Sui blockchain with on-chain rate calculations, providing more frequent arbitrage opportunities but requiring gas fees for position adjustments. MEXC's zero maker fees benefit funding arbitrageurs, while Bluefin's hourly intervals allow for more responsive rate corrections but higher transaction frequency."}]]}]
7:["$","$Lb",null,{"items":[{"question":"Which exchange offers better funding rate arbitrage opportunities?","answer":"MEXC provides zero maker fees and more diverse altcoin perpetuals, while Bluefin offers hourly funding intervals for more frequent arbitrage windows. Choice depends on preferred trading frequency and token selection."},{"question":"How do the funding calculation methods differ between MEXC and Bluefin?","answer":"MEXC uses centralized premium calculations updated every 8 hours, while Bluefin calculates rates on-chain hourly using Sui's consensus mechanism. Bluefin's approach offers more transparency but requires understanding of on-chain mechanics."},{"question":"What are the main risks when arbitraging between these platforms?","answer":"MEXC carries counterparty risk and potential volume inflation, while Bluefin faces smart contract risk and Sui network dependencies. Both require careful position sizing due to liquidity differences."},{"question":"Which platform is better for institutional funding rate strategies?","answer":"MEXC offers higher leverage and established infrastructure but lacks regulatory clarity. Bluefin provides transparent on-chain operations and professional trading tools but has limited institutional adoption in the Sui ecosystem."}]}]
