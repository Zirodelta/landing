6:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Gate.io uses traditional 8-hour funding intervals with rates determined by perpetual-spot price divergence across its 1,700+ pairs. RabbitX implements 1-hour funding cycles on Starknet, allowing more frequent rate adjustments but with limited pair selection. Gate's broader market coverage creates more arbitrage opportunities, while RabbitX's hourly cycles reduce overnight funding exposure. Both use mark-to-index pricing but RabbitX benefits from lower settlement costs due to L2 infrastructure."}]]}]
7:["$","$Lb",null,{"items":[{"question":"Which exchange offers better funding rate opportunities?","answer":"Gate.io provides more arbitrage opportunities due to its 1,700+ pairs and established liquidity pools. RabbitX offers faster rate adjustments with 1-hour intervals but limited to major tokens only."},{"question":"How do funding rate calculations differ between these platforms?","answer":"Both use mark-to-index pricing, but Gate.io calculates rates every 8 hours across diverse markets while RabbitX updates hourly on Starknet. Gate's broader coverage creates more rate divergence opportunities."},{"question":"Which platform has lower overall trading costs for funding arbitrage?","answer":"Gate.io offers lower maker fees at 0.015% versus RabbitX's 0.02%, but RabbitX eliminates gas fees entirely. For high-frequency funding strategies, RabbitX's gas-free environment may offset the higher maker fees."},{"question":"What are the main operational differences for arbitrageurs?","answer":"Gate.io requires traditional CEX deposits and KYC but offers immediate access to all pairs. RabbitX operates on Starknet requiring L2 bridging but provides decentralized execution with cross-margin capabilities."}]}]
