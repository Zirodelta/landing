6:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Both exchanges use identical 1-hour funding intervals, making them suitable for short-term arbitrage strategies. Hyperliquid's on-chain order book provides transparent funding rate calculations, while Bluefin leverages Sui's fast finality for rapid position management. The key difference lies in liquidity depth - Hyperliquid typically shows higher volume which can lead to more stable funding rates, while Bluefin's rates may be more volatile due to lower liquidity but offer potential for larger spreads."}]]}]
7:["$","$Lc",null,{"items":[{"question":"Which exchange offers better funding rate arbitrage opportunities?","answer":"Hyperliquid generally provides more stable opportunities due to higher liquidity, while Bluefin may offer larger spreads but with increased volatility risk in the smaller Sui ecosystem."},{"question":"Do both exchanges support cross-collateral margin trading?","answer":"Hyperliquid uses USDC as primary collateral with some multi-asset support, while Bluefin supports various Sui-native tokens. Both offer portfolio margin but with different underlying assets."},{"question":"How do gas costs compare for frequent trading?","answer":"Hyperliquid's L1 offers predictable low costs, while Sui's gas fees are generally minimal. Both are significantly cheaper than Ethereum-based alternatives for high-frequency arbitrage strategies."},{"question":"Which platform is better for institutional arbitrage strategies?","answer":"Hyperliquid currently offers better institutional infrastructure and higher liquidity. Bluefin provides professional tools but operates in a smaller ecosystem with less institutional adoption."}]}]
