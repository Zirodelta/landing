7:["$","section",null,{"className":"mb-12","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Rate Mechanics"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"KuCoin calculates funding rates every 8 hours using traditional premium/discount methodology tied to spot price divergence. Orderly Network implements hourly funding settlements through its shared infrastructure, allowing for more frequent rate adjustments across all connected DEX frontends. The 1-hour intervals on Orderly can capture shorter-term market inefficiencies but may result in higher transaction frequency costs for arbitrageurs."}]]}]
8:["$","$Ld",null,{"items":[{"question":"How do funding intervals affect arbitrage opportunities between KuCoin and Orderly?","answer":"KuCoin's 8-hour intervals provide longer rate prediction windows but fewer capture opportunities. Orderly's 1-hour settlements offer more frequent arbitrage windows but require faster execution and may increase gas costs on blockchain transactions."},{"question":"Which platform offers better liquidity for perpetual futures arbitrage?","answer":"KuCoin provides established liquidity pools for major trading pairs with proven market depth. Orderly Network aggregates liquidity across multiple frontends, potentially offering better combined depth but with execution complexity varying by frontend choice."},{"question":"What are the regulatory considerations when arbitraging between these platforms?","answer":"KuCoin faces ongoing SEC compliance issues that may affect US-based traders. Orderly Network operates as decentralized infrastructure, but users must consider the regulatory status of their chosen frontend application and jurisdiction-specific DeFi regulations."},{"question":"How do collateral requirements differ for perpetual trading?","answer":"KuCoin primarily uses USDT-based margin systems with standard maintenance requirements. Orderly Network supports multi-asset collateral through its infrastructure layer, with specific requirements determined by the frontend application and underlying blockchain protocols."}]}]
