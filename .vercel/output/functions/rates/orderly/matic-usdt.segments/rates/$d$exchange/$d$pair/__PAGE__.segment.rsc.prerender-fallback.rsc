3:["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":["How Funding Works on ","Orderly Network"]}]
4:["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Orderly Network calculates MATIC/USDT funding rates hourly based on the premium between perpetual and spot prices across its shared order book. The funding mechanism operates independently of individual frontend interfaces, with settlements processed through the underlying infrastructure layer. Long positions pay funding when rates are positive, while shorts pay when negative, with payments distributed proportionally across all connected frontends. The shared liquidity model can create unique funding dynamics compared to isolated exchange environments."}]
5:["$","section",null,{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":["Why ","MATIC","/","USDT","?"]}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"MATIC's role as Polygon's native token drives significant perpetual trading volume and frequent funding rate fluctuations. The token's correlation with Ethereum ecosystem developments and L2 scaling narratives creates predictable funding patterns during network upgrades or DeFi activity surges. Orderly's multi-chain accessibility allows arbitrageurs to capture MATIC funding opportunities from both NEAR and EVM ecosystems simultaneously."}]]}]
6:["$","section","0",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Historical MATIC Funding Patterns"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"MATIC funding rates on Orderly Network typically range from -0.01% to +0.05% hourly, with notable spikes during Polygon network events or broader L2 market movements. The shared liquidity model often results in more stable funding rates compared to isolated exchanges, as arbitrage flows balance across multiple frontends. Historical data shows MATIC funding correlates strongly with Ethereum gas prices and DeFi TVL migrations. Weekend periods often see reduced funding volatility due to lower institutional trading activity across the shared order book."}]]}]
7:["$","section","1",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Multi-Chain Arbitrage Opportunities"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Orderly's infrastructure enables unique cross-chain arbitrage strategies for MATIC funding rates, allowing traders to access positions from both NEAR and EVM environments. The shared order book creates opportunities to exploit funding differentials between Orderly and single-chain perpetual platforms. Arbitrageurs can leverage the platform's white-label frontend ecosystem to identify the most favorable entry points for funding strategies. Cross-chain bridge delays must be factored into arbitrage calculations, particularly for time-sensitive hourly funding captures."}]]}]
8:["$","section","2",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Risk Management Considerations"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Orderly's dependence on frontend partners introduces counterparty risks not present in traditional centralized exchanges, requiring careful selection of access points. The shared liquidity model can create unexpected slippage during high volatility periods when multiple frontends compete for the same order book depth. Smart contract risks exist across the multi-chain infrastructure, with potential impacts from both NEAR protocol and EVM chain vulnerabilities. Funding rate arbitrageurs should monitor the health of connected frontends and maintain diversified access routes to the underlying Orderly infrastructure."}]]}]
9:["$","$Le",null,{"items":[{"question":"How does Orderly Network's shared order book affect MATIC funding rates?","answer":"The shared order book aggregates liquidity from multiple DEX frontends, typically creating more stable MATIC funding rates than isolated exchanges. However, funding calculations remain sensitive to the combined position imbalances across all connected platforms."},{"question":"Can I access MATIC perpetuals on Orderly from different blockchains?","answer":"Yes, Orderly Network supports access from both NEAR Protocol and EVM-compatible chains. This multi-chain accessibility allows for diverse arbitrage strategies and cross-chain funding rate comparisons."},{"question":"What happens to my MATIC position if a frontend partner fails?","answer":"Your position exists on the underlying Orderly infrastructure, not the specific frontend. You can typically access and manage positions through alternative frontend partners, though some disruption may occur during transitions."},{"question":"How do Orderly's 0.02%/0.05% fees impact MATIC funding arbitrage profitability?","answer":"The maker/taker fee structure requires funding rate differentials to exceed approximately 0.04-0.10% to remain profitable after costs. Orderly's competitive fees generally support viable arbitrage strategies for MATIC's typical funding volatility."}]}]
