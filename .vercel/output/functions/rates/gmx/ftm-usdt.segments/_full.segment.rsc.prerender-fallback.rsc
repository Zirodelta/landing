f:["$","section",null,{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":["Why ","FTM","/","USDT","?"]}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"FTM/USDT presents compelling arbitrage opportunities due to Fantom's correlation with broader DeFi trends and moderate trading volume. The pair often experiences sustained funding rate imbalances during Fantom ecosystem developments or DeFi sector rotations, creating profitable carry trade setups for patient arbitrageurs."}]]}]
10:["$","section","0",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Historical Funding Rate Patterns"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"FTM/USDT funding rates on GMX typically range from -0.1% to +0.3% annually, with notable spikes during Fantom protocol launches or DeFi summer periods. The oracle-based mechanism tends to produce more stable rates than order book exchanges, though extreme market conditions can push hourly rates beyond ±0.01%. Extended periods of positive funding often coincide with Fantom DApp launches or cross-chain bridge activity, while negative rates emerge during broader L1 token selloffs."}]]}]
11:["$","section","1",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Arbitrage Strategy Considerations"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Successful FTM funding arbitrage on GMX requires monitoring both the perpetual position and potential spot hedge execution costs across multiple chains. The 0.05% opening fee and 0.07% closing fee must be factored into minimum profitable funding thresholds, typically requiring rates above 0.02% hourly for short-term plays. Cross-exchange arbitrage with centralized platforms can be profitable when GMX funding diverges significantly from CEX rates, though Arbitrum bridging costs and timing must be considered."}]]}]
12:["$","section","2",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Risk Management Framework"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"Oracle dependency represents the primary risk for FTM positions on GMX, as Chainlink feed delays or manipulation could trigger unexpected liquidations. Position sizing should account for GMX's dynamic borrowing fees, which increase with pool utilization and can erode funding profits during high-demand periods. The platform's maximum leverage limits and lack of isolated margin require careful capital allocation, especially when hedging funding positions across multiple exchanges or chains."}]]}]
13:["$","$L15",null,{"items":[{"question":"How often are FTM/USDT funding payments made on GMX?","answer":"GMX pays funding every hour automatically, unlike most exchanges that use 8-hour intervals. This creates more frequent but smaller payment amounts, allowing for more precise funding rate arbitrage strategies."},{"question":"Can I hedge FTM perpetual positions with spot tokens on other chains?","answer":"Yes, but factor in Arbitrum bridge costs and timing when hedging FTM perpetuals with spot FTM on Fantom or other chains. Cross-chain arbitrage opportunities exist but require careful cost analysis including gas fees and bridge delays."},{"question":"What makes GMX funding rates different from centralized exchanges?","answer":"GMX uses oracle prices rather than order book dynamics to calculate funding, often resulting in different rates than CEXs. The GLP pool structure and hourly payments create unique arbitrage opportunities compared to traditional 8-hour funding cycles."},{"question":"How do GMX's borrowing fees affect FTM funding arbitrage?","answer":"Borrowing fees on GMX increase with pool utilization and are charged hourly separate from funding rates. During high demand periods, these fees can exceed funding income, making it crucial to monitor pool utilization metrics before opening positions."}]}]
