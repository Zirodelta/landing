3:["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":["How Funding Works on ","RabbitX"]}]
4:["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"RabbitX calculates SEI/USDT funding rates every hour using a time-weighted average of the premium/discount to spot prices across multiple venues. The exchange's Starknet settlement layer processes funding payments automatically without requiring manual claims or gas fees from traders. Cross-margin functionality allows positions to be funded from the entire account balance, reducing liquidation risks during volatile funding periods. Funding rates are applied to the notional position value, with longs paying shorts when rates are positive and vice versa."}]
5:["$","section",null,{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":["Why ","SEI","/","USDT","?"]}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"SEI's position as a specialized blockchain for trading applications creates unique funding rate dynamics compared to general-purpose L1 tokens. The token's correlation with DeFi trading volumes and exchange performance metrics generates predictable funding rate patterns during market stress. RabbitX's zero-gas environment makes frequent position adjustments economically viable for capturing small funding rate differentials."}]]}]
6:["$","section","0",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"SEI Funding Rate Historical Patterns"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"SEI funding rates on RabbitX typically range from -0.05% to +0.08% hourly, with extreme rates reaching ±0.2% during major market events. Positive funding rates dominate during SEI ecosystem announcements or integrations with major DEX protocols. The token shows seasonal patterns with higher funding costs during quarterly unlock events and validator reward distributions. Cross-exchange arbitrage opportunities frequently emerge when RabbitX rates deviate from Binance or OKX by more than 0.02% hourly."}]]}]
7:["$","section","1",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Arbitrage Execution Strategies"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"RabbitX's zero-gas trading enables micro-arbitrage strategies focusing on funding rate mean reversion over 2-4 hour periods. The optimal approach involves maintaining neutral delta exposure while capturing funding differentials between RabbitX and centralized exchanges. Cross-margin functionality allows leveraging up to 20x on SEI positions while maintaining adequate margin for funding payments. Position sizing should account for SEI's moderate volatility and the exchange's limited liquidity during off-peak hours."}]]}]
8:["$","section","2",{"className":"mb-10","children":[["$","h2",null,{"className":"text-2xl font-extrabold tracking-tight text-foreground mt-12 mb-4","style":{"fontFamily":"var(--font-montserrat), sans-serif"},"children":"Risk Management Considerations"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed","children":"SEI's mid-tier trading volume on RabbitX creates slippage risks for positions above $10,000 notional value during market stress. The exchange's early-stage protocol status introduces smart contract risks and potential liquidity crises during extreme market conditions. Funding rate arbitrage positions should be monitored closely due to RabbitX's hourly settlement frequency and SEI's tendency for sudden price movements. Consider hedging exposure through spot SEI holdings or correlated L1 token positions on more liquid venues."}]]}]
9:["$","$Le",null,{"items":[{"question":"How often are SEI funding rates calculated on RabbitX?","answer":"RabbitX calculates and applies SEI/USDT funding rates every hour using time-weighted premium calculations. The exchange's Starknet infrastructure automatically processes funding payments without requiring gas fees or manual intervention from traders."},{"question":"What makes SEI funding rates unique on RabbitX compared to CEX platforms?","answer":"RabbitX's zero-gas environment and cross-margin system create different funding dynamics, often showing 0.01-0.03% hourly deviations from centralized exchanges. The DEX's smaller user base can amplify funding rate movements during periods of directional SEI sentiment."},{"question":"Can I use cross-margin for SEI funding rate arbitrage on RabbitX?","answer":"Yes, RabbitX supports cross-margin trading for SEI/USDT positions, allowing your entire account balance to back funding rate arbitrage strategies. This reduces liquidation risk but requires careful position sizing due to SEI's volatility and the platform's limited liquidity depth."},{"question":"What are the typical funding costs for holding SEI positions on RabbitX?","answer":"SEI funding rates on RabbitX average 0.01-0.03% hourly, translating to approximately 2.6-7.9% annually for long positions. During SEI ecosystem developments or major DeFi integrations, rates can spike to 0.1%+ hourly, creating significant arbitrage opportunities against other venues."}]}]
